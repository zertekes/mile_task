{
  "name": "mile-detox-e2e-template",
  "version": "0.1.0",
  "private": true,
  "description": "Detox E2E scaffold for iOS simulator flows",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "typecheck:e2e": "tsc -p tsconfig.json --noEmit",
    "e2e:build": "detox build -c ios.sim.debug",
    "e2e:test": "detox test -c ios.sim.debug --cleanup",
    "e2e:test:headless": "detox test -c ios.sim.debug --headless --cleanup",
    "e2e": "yarn typecheck:e2e && yarn e2e:build && yarn e2e:test"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "detox": "^20.25.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
